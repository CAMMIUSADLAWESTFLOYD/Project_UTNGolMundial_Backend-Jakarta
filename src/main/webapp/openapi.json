{
  "openapi": "3.0.1",
  "info": {
    "title": "Servicio UTNGolCoin API",
    "description": "API REST para la gestión de la moneda virtual UTNGolCoin y predicciones del Mundial",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/UTNGolCoin/api",
      "description": "Servidor WildFly Local API"
    }
  ],
  "paths": {
    "/usuarios/registrar": {
      "post": {
        "tags": ["Usuarios"],
        "summary": "Registrar usuario y billetera",
        "description": "Registra usuario y crea su billetera llamando a sp_registrar_usuario_billetera",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UsuarioBilleteraRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuario registrado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MensajeResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/usuarios/{id}": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Buscar usuario por ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuario encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Usuario"
                }
              }
            }
          }
        }
      }
    },
    "/billeteras/usuario/{usuarioId}": {
      "get": {
        "tags": ["Billeteras"],
        "summary": "Consultar billetera por usuario",
        "parameters": [
          {
            "name": "usuarioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Billetera encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BilleteraResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/billeteras/{billeteraId}/transacciones": {
      "get": {
        "tags": ["Billeteras"],
        "summary": "Listar transacciones de billetera",
        "parameters": [
          {
            "name": "billeteraId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de transacciones",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transaccion"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/predicciones/registrar": {
      "post": {
        "tags": ["Predicciones"],
        "summary": "Registrar prediccion",
        "description": "Registra una nueva prediccion llamando a sp_registrar_prediccion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrediccionRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prediccion registrada con exito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MensajeResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/predicciones/liquidar": {
      "post": {
        "tags": ["Predicciones"],
        "summary": "Liquidar predicciones de partido",
        "description": "Liquida predicciones llamando a sp_liquidar_predicciones_partido",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LiquidacionRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Liquidacion procesada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MensajeResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/predicciones/usuario/{usuarioId}": {
      "get": {
        "tags": ["Predicciones"],
        "summary": "Listar predicciones de usuario",
        "parameters": [
          {
            "name": "usuarioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de predicciones del usuario",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Prediccion"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/bonos/otorgar": {
      "post": {
        "tags": ["Bonos Diarios"],
        "summary": "Otorgar bono diario",
        "description": "Otorga el bono diario al usuario llamando a sp_otorgar_bono_diario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BonoDiarioRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bono diario otorgado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MensajeResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/bonos/usuario/{usuarioId}": {
      "get": {
        "tags": ["Bonos Diarios"],
        "summary": "Listar bonos diarios de usuario",
        "parameters": [
          {
            "name": "usuarioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Historial de bonos diarios",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BonoDiario"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UsuarioBilleteraRequestDto": {
        "type": "object",
        "properties": {
          "username": { "type": "string", "example": "juanperez" },
          "nombre": { "type": "string", "example": "Juan Perez" },
          "email": { "type": "string", "example": "juan@email.com" },
          "rolId": { "type": "integer", "format": "int64", "example": 1 }
        }
      },
      "PrediccionRequestDto": {
        "type": "object",
        "properties": {
          "usuarioId": { "type": "integer", "format": "int64", "example": 1 },
          "partidoId": { "type": "integer", "format": "int64", "example": 10 },
          "tipoResultado": { "type": "string", "example": "LOCAL" },
          "monto": { "type": "number", "example": 50.0 }
        }
      },
      "LiquidacionRequestDto": {
        "type": "object",
        "properties": {
          "partidoId": { "type": "integer", "format": "int64", "example": 10 },
          "resultadoFinal": { "type": "string", "example": "LOCAL" }
        }
      },
      "BonoDiarioRequestDto": {
        "type": "object",
        "properties": {
          "usuarioId": { "type": "integer", "format": "int64", "example": 1 }
        }
      },
      "BilleteraResponseDto": {
        "type": "object",
        "properties": {
          "billeteraId": { "type": "integer", "format": "int64" },
          "usuarioId": { "type": "integer", "format": "int64" },
          "username": { "type": "string" },
          "saldo": { "type": "number" }
        }
      },
      "MensajeResponseDto": {
        "type": "object",
        "properties": {
          "mensaje": { "type": "string" },
          "exitoso": { "type": "boolean" }
        }
      },
      "Usuario": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "username": { "type": "string" },
          "nombre": { "type": "string" },
          "email": { "type": "string" },
          "rolId": { "type": "integer", "format": "int64" },
          "activo": { "type": "boolean" },
          "fechaRegistro": { "type": "string" },
          "fechaSync": { "type": "string" }
        }
      },
      "Prediccion": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "usuarioId": { "type": "integer", "format": "int64" },
          "partidoId": { "type": "integer", "format": "int64" },
          "tipoResultado": { "type": "string" },
          "monto": { "type": "number" },
          "cuotaAplicada": { "type": "number" },
          "estado": { "type": "string" },
          "fechaCreacion": { "type": "string" },
          "fechaLiquidacion": { "type": "string" }
        }
      },
      "BonoDiario": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "usuarioId": { "type": "integer", "format": "int64" },
          "fecha": { "type": "string" },
          "monto": { "type": "number" },
          "transaccionId": { "type": "integer", "format": "int64" },
          "fechaOtorgado": { "type": "string" }
        }
      },
      "Transaccion": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "billeteraId": { "type": "integer", "format": "int64" },
          "tipo": { "type": "string" },
          "monto": { "type": "number" },
          "saldoResultante": { "type": "number" },
          "prediccionId": { "type": "integer", "format": "int64" },
          "descripcion": { "type": "string" },
          "fecha": { "type": "string" }
        }
      }
    }
  }
}
