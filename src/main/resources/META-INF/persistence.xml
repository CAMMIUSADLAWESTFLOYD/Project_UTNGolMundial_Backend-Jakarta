<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="UTNGolCoinPU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/UTNGolCoinDS</jta-data-source>
        
        <class>ec.edu.utn.golmundial.modelos.Usuario</class>
        <class>ec.edu.utn.golmundial.modelos.Rol</class>
        <class>ec.edu.utn.golmundial.modelos.Billetera</class>
        <class>ec.edu.utn.golmundial.modelos.Transaccion</class>
        <class>ec.edu.utn.golmundial.modelos.Prediccion</class>
        <class>ec.edu.utn.golmundial.modelos.Partido</class>
        <class>ec.edu.utn.golmundial.modelos.BonoDiario</class>
        <class>ec.edu.utn.golmundial.modelos.Auditoria</class>

        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MariaDBDialect"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
